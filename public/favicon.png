<?xml version="1.0" encoding="UTF-8"?>
<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 600 200">
  <!-- ADB Logo -->
  <g fill="#0057A6">
    <!-- Letter A -->
    <path d="M50,150 L100,20 L140,20 L190,150 L150,150 L140,120 L100,120 L90,150 Z M110,50 L105,100 L135,100 L130,50 Z"/>
    
    <!-- Letter D with bearing circles -->
    <path d="M210,20 L270,20 C320,20 360,50 360,85 C360,120 320,150 270,150 L210,150 Z M250,50 L250,120 C290,120 310,105 310,85 C310,65 290,50 250,50 Z"/>
    
    <!-- Bearing circles -->
    <circle cx="250" cy="50" r="8"/>
    <circle cx="265" cy="55" r="8"/>
    <circle cx="280" cy="65" r="8"/>
    <circle cx="290" cy="75" r="8"/>
    <circle cx="290" cy="95" r="8"/>
    <circle cx="280" cy="105" r="8"/>
    <circle cx="265" cy="115" r="8"/>
    <circle cx="250" cy="120" r="8"/>
    
    <!-- Chinese characters at the bottom -->
    <path d="M50,170 L70,170 L70,180 L50,180 Z M55,160 L65,160 L65,190 L55,190 Z"/>
    <path d="M90,160 L130,160 L130,170 L90,170 Z M90,175 L130,175 L130,185 L90,185 Z"/>
    <path d="M150,160 L190,160 L190,190 L150,190 Z M160,170 L180,170 L180,180 L160,180 Z"/>
    <path d="M210,160 L230,160 L230,190 L210,190 Z M220,165 L240,165 L240,185 L220,185 Z"/>
    <path d="M260,160 L280,160 L280,190 L260,190 Z M270,165 L290,165 L290,185 L270,185 Z"/>
    <path d="M310,160 L350,160 L350,190 L310,190 Z M320,170 L340,170 L340,180 L320,180 Z"/>
  </g>
</svg> 