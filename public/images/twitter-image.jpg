<?xml version="1.0" encoding="UTF-8"?>
<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 630">
  <rect width="1200" height="630" fill="#FFFFFF"/>
  
  <!-- ADB Logo (centered and scaled) -->
  <g transform="translate(300, 150) scale(1.5)">
    <path d="M34.5,50 L100,250 L150,250 L120,150 L180,150 L210,250 L260,250 L195,50 L145,50 L170,130 L110,130 L85,50 Z" fill="#0057A6"/>
    <path d="M270,50 L270,250 L320,250 L320,180 L380,180 C420,180 450,150 450,115 C450,80 420,50 380,50 Z M320,90 L370,90 C390,90 400,100 400,115 C400,130 390,140 370,140 L320,140 Z" fill="#0057A6"/>
    <path d="M460,50 L460,250 L510,250 L510,50 Z" fill="#0057A6"/>
    <!-- Circles in the D -->
    <circle cx="345" cy="115" r="10" fill="#FFFFFF"/>
    <circle cx="345" cy="85" r="10" fill="#FFFFFF"/>
    <circle cx="345" cy="145" r="10" fill="#FFFFFF"/>
    <circle cx="370" cy="130" r="10" fill="#FFFFFF"/>
    <circle cx="370" cy="100" r="10" fill="#FFFFFF"/>
    <circle cx="395" cy="115" r="10" fill="#FFFFFF"/>
  </g>
  
  <!-- Company name in English -->
  <text x="600" y="450" font-family="Arial, sans-serif" font-size="40" font-weight="bold" text-anchor="middle" fill="#0057A6">Suzhou Bei Ren Bearing Sales Co., Ltd.</text>
  
  <!-- Company name in Chinese -->
  <text x="600" y="510" font-family="Arial, sans-serif" font-size="40" font-weight="bold" text-anchor="middle" fill="#0057A6">苏州北人轴承销售有限公司</text>
</svg> 